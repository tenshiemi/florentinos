---
import { getSiteSettings } from '../lib/sanity';

const year = new Date().getFullYear();
const settings = await getSiteSettings().catch(() => null);

const brandName = settings?.businessName ?? "Florentino's Fine Flowers";
const tagline   = settings?.tagline      ?? 'Madison Valley · Seattle';
const instagram = settings?.socialLinks?.instagram ?? 'https://www.instagram.com/florentinosseattle';
const facebook  = settings?.socialLinks?.facebook  ?? 'https://www.facebook.com/florentinosseattle';
const yelp      = settings?.socialLinks?.yelp      ?? 'https://www.yelp.com/biz/florentinos-fine-flowers-seattle';
---
<footer class="footer">
  <div class="footer-inner">
    <p class="footer-brand">{brandName}</p>
    <p class="footer-sub">{tagline}</p>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/gallery">Gallery</a>
      <a href="/order">Order</a>
      <a href="/subscribe">Subscribe</a>
      <a href="/about">About</a>
      <a href="/visit">Visit</a>
    </nav>
    <nav class="footer-social" aria-label="Social media">
      <a href={instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a href={facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <a href={yelp} target="_blank" rel="noopener noreferrer" aria-label="Yelp">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 0 1 1.596-.206 9.024 9.024 0 0 1 2.364 3.48 1.073 1.073 0 0 1-.694 1.231zm-6.415 3.171l4.728 2.04a1.073 1.073 0 0 1 .46 1.545 9.01 9.01 0 0 1-2.976 2.853 1.073 1.073 0 0 1-1.52-.545l-1.77-4.826c-.34-.928.772-1.726 1.578-1.067zm-5.513 4.88l1.35-5.033c.26-.97 1.593-1.025 1.926-.085l1.73 4.842a1.07 1.07 0 0 1-.654 1.378 9.073 9.073 0 0 1-3.99.201 1.07 1.07 0 0 1-.862-1.303zm-5.789-5.5a9.017 9.017 0 0 1-.104-4.27 1.073 1.073 0 0 1 1.415-.768l4.93 1.686c.94.322.894 1.668-.068 1.925l-4.998 1.432a1.073 1.073 0 0 1-1.175-1.005zm4.15-8.57a9.024 9.024 0 0 1 3.624-1.989 1.073 1.073 0 0 1 1.307.855l.828 5.13c.16.99-.994 1.599-1.693.876L5.55 7.264a1.072 1.072 0 0 1 .044-1.69z"/>
        </svg>
      </a>
    </nav>
    <p class="footer-copy">&copy; {year} {brandName}. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy);
    border-top: 1px solid rgba(255,225,132,0.15);
    padding: 3rem var(--space-content);
    text-align: center;
  }
  .footer-inner { max-width: var(--max-width); margin: 0 auto; }
  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-gold);
    margin-bottom: 0.25rem;
  }
  .footer-sub { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: #888; margin-bottom: 1.5rem; }
  .footer-links { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .footer-links a { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #aaa; }
  .footer-links a:hover { color: var(--color-gold); }
  .footer-social { display: flex; justify-content: center; gap: 1.5rem; margin-bottom: 1.5rem; }
  .footer-social a { color: #666; transition: color var(--transition-base); display: flex; }
  .footer-social a:hover { color: var(--color-gold); }
  .footer-social a:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 4px; }
  .footer-copy { font-size: 11px; color: #555; }
</style>
